{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trustinfrastructure.com/cornerstone/schemas/professional-credential.json",
  "title": "Professional Credential",
  "type": "object",
  "description": "The Professional Credential schema captures the relationship between a verified individual and their employer or organization, confirming active affiliation without embedding identity or licensing details.",
  "properties": {
    "credentialSubject": {
      "type": "object",
      "properties": {
        "cornerstone_id": {
          "title": "Cornerstone Id",
          "type": "string"
        },
        "employer_name": {
          "title": "Employer Name",
          "type": "string"
        },
        "role_title": {
          "title": "Role Title",
          "type": "string"
        },
        "affiliation_type": {
          "title": "Affiliation Type",
          "type": "string"
        },
        "start_date": {
          "title": "Start Date",
          "type": "string",
          "format": "date"
        },
        "team_office": {
          "title": "Team Office",
          "type": "string"
        }
      },
      "required": [
        "cornerstone_id",
        "employer_name",
        "role_title",
        "affiliation_type",
        "start_date",
        "team_office"
      ],
      "additionalProperties": false
    }
  }
}