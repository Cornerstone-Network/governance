{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trustinfrastructure.com/cornerstone/schemas/cornerstone-id.json",
  "title": "Cornerstone ID",
  "type": "object",
  "description": "The Cornerstone ID schema captures verified identity attributes for an individual, serving as the base credential that all other Cornerstone credentials reference via cornerstone_id. It contains only what it uniquely attests to — verified identity — with no role, property, employment, or derived data.",
  "properties": {
    "credentialSubject": {
      "type": "object",
      "properties": {
        "given_names": {
          "title": "Given Names",
          "type": "string"
        },
        "family_name": {
          "title": "Family Name",
          "type": "string"
        },
        "birthdate": {
          "title": "Birthdate",
          "type": "string",
          "format": "date"
        },
        "verified_email": {
          "title": "Verified Email",
          "type": "string",
          "format": "email"
        },
        "verified_phone": {
          "title": "Verified Phone",
          "type": "string"
        },
        "cornerstone_user_id": {
          "title": "Cornerstone User Id",
          "type": "string",
          "format": "uuid"
        },
        "postal_address": {
          "title": "Postal Address",
          "type": "object",
          "properties": {
            "street_address": {
              "title": "Street Address",
              "type": "string"
            },
            "locality": {
              "title": "Locality",
              "type": "string"
            },
            "region": {
              "title": "Region",
              "type": "string"
            },
            "postal_code": {
              "title": "Postal Code",
              "type": "string"
            },
            "country": {
              "title": "Country",
              "type": "string"
            }
          },
          "required": [
            "street_address",
            "locality",
            "region",
            "postal_code",
            "country"
          ],
          "additionalProperties": false
        },
        "identity_evidence": {
          "title": "Identity Evidence",
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "given_names",
        "family_name",
        "birthdate",
        "verified_email",
        "verified_phone",
        "cornerstone_user_id",
        "postal_address",
        "identity_evidence"
      ],
      "additionalProperties": false
    }
  }
}