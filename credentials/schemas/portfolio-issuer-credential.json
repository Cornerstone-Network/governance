{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trustinfrastructure.com/cornerstone/schemas/portfolio-issuer.json",
  "title": "Portfolio Issuer Credential",
  "type": "object",
  "description": "The Portfolio Issuer schema captures a delegation of authority from a Network Partner to an individual professional, defining what they are authorized to do within the ecosystem.",
  "properties": {
    "credentialSubject": {
      "type": "object",
      "properties": {
        "cornerstone_id": {
          "title": "Cornerstone Id",
          "type": "string"
        },
        "portfolio_issuer_id": {
          "title": "Portfolio Issuer Id",
          "type": "string",
          "format": "uuid"
        },
        "network_partner_id": {
          "title": "Network Partner Id",
          "type": "string",
          "format": "uuid"
        },
        "network_partner_name": {
          "title": "Network Partner Name",
          "type": "string"
        },
        "granted_date": {
          "title": "Granted Date",
          "type": "string",
          "format": "date-time"
        },
        "granting_authority": {
          "title": "Granting Authority",
          "type": "string"
        },
        "scope": {
          "title": "Scope",
          "type": "object",
          "properties": {
            "regions": {
              "title": "Regions",
              "type": "array",
              "items": {
                "title": "Item",
                "type": "string"
              }
            },
            "offices": {
              "title": "Offices",
              "type": "array",
              "items": {
                "title": "Item",
                "type": "string"
              }
            }
          },
          "required": [
            "regions",
            "offices"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "cornerstone_id",
        "portfolio_issuer_id",
        "network_partner_id",
        "network_partner_name",
        "granted_date",
        "granting_authority",
        "scope"
      ],
      "additionalProperties": false
    }
  }
}