{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trustinfrastructure.com/cornerstone/schemas/property-access-authorization.json",
  "title": "Property Access Authorization Credential",
  "type": "object",
  "description": "The PAAC schema captures a homeowner's consent to share specific property data categories with a specific recipient, at a defined access level, for a stated purpose.",
  "properties": {
    "credentialSubject": {
      "type": "object",
      "properties": {
        "authorization_id": {
          "title": "Authorization Id",
          "type": "string",
          "format": "uuid"
        },
        "homeowner_id": {
          "title": "Homeowner Id",
          "type": "string"
        },
        "pid": {
          "title": "Pid",
          "type": "string"
        },
        "data_scope": {
          "title": "Data Scope",
          "type": "array",
          "items": {
            "title": "Item",
            "type": "string"
          }
        },
        "authorization_purpose": {
          "title": "Authorization Purpose",
          "type": "string"
        },
        "access_level": {
          "title": "Access Level",
          "type": "string"
        },
        "relationship_category": {
          "title": "Relationship Category",
          "type": "string"
        },
        "start_date": {
          "title": "Start Date",
          "type": "string",
          "format": "date-time"
        },
        "expiration_date": {
          "title": "Expiration Date",
          "type": "string",
          "format": "date-time"
        },
        "authorization_evidence": {
          "title": "Authorization Evidence",
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "authorization_id",
        "homeowner_id",
        "pid",
        "data_scope",
        "authorization_purpose",
        "access_level",
        "relationship_category",
        "start_date",
        "expiration_date",
        "authorization_evidence"
      ],
      "additionalProperties": false
    }
  }
}